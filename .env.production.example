# ─────────────────────────────────────────────────────────────────────────────
# Pawn Stars — Production Environment Variables
#
# Copy this file to .env (never commit .env) and fill in real values.
# All variables without a default are REQUIRED for the API to start.
# Set these in Railway's environment variable dashboard for the api service.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────────────────

# Runtime environment — must be "production" in production deployments
NODE_ENV=production

# Port the NestJS API listens on — Railway injects this automatically
PORT=3001

# Fully-qualified public URL of the Next.js frontend (no trailing slash)
# Used for CORS allow-origin header — must match your Vercel domain exactly
FRONTEND_URL=https://pawnstars.vercel.app

# ─── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string provided by Railway's Postgres plugin
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?sslmode=require
# Railway injects this automatically when you add a Postgres service
DATABASE_URL=postgresql://postgres:<password>@<railway-host>:5432/railway?sslmode=require

# ─── Auth / JWT ───────────────────────────────────────────────────────────────

# Secret used to sign and verify JWT tokens — minimum 32 random bytes
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-character-hex-string

# Token expiry — standard values: 7d, 24h, 1h
JWT_EXPIRES_IN=7d

# ─── External APIs ────────────────────────────────────────────────────────────

# Lichess public API base URL — do not change unless Lichess changes their API
LICHESS_API_URL=https://lichess.org/api

# Lichess personal access token for authenticated endpoints (rating import)
# Generate at: https://lichess.org/account/oauth/token
# Required scopes: (none — public endpoints only)
LICHESS_API_TOKEN=lip_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cache / Redis ────────────────────────────────────────────────────────────

# Redis connection URL provided by Railway's Redis plugin
# Railway injects this automatically when you add a Redis service
REDIS_URL=redis://default:<password>@<railway-redis-host>:6379

# ─── Search / Meilisearch ─────────────────────────────────────────────────────

# Public URL of your Railway Meilisearch service (no trailing slash)
MEILISEARCH_HOST=https://meilisearch.<railway-domain>.railway.app

# Meilisearch master key — set during Meilisearch startup
# Generate with: openssl rand -hex 32
MEILISEARCH_API_KEY=change-me-to-a-random-meilisearch-master-key

# ─── Email / Resend ───────────────────────────────────────────────────────────

# Resend API key for transactional and newsletter email sends
# Get yours at: https://resend.com/api-keys
# Required permissions: Full access (or send:email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address used for all outgoing emails
# Must be from a domain verified in your Resend dashboard
EMAIL_FROM=noreply@pawnstars.com

# ─── AI / Anthropic ───────────────────────────────────────────────────────────

# Anthropic API key for post-tournament article generation via Claude
# Get yours at: https://console.anthropic.com
# Leave blank to use the built-in mock fallback (returns hardcoded article)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Storage / AWS S3 ─────────────────────────────────────────────────────────

# AWS credentials for S3 media storage — use an IAM user with minimal permissions
# Required S3 permissions: s3:PutObject, s3:GetObject, s3:DeleteObject
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# Public media bucket — player photos, press assets, gallery (served via CloudFront)
AWS_S3_PUBLIC_BUCKET=pawnstars-public-media

# Private assets bucket — player study materials (requires signed URLs)
AWS_S3_PRIVATE_BUCKET=pawnstars-private-assets

# CloudFront CDN base URL for public media (no trailing slash)
CLOUDFRONT_URL=https://d1234567890.cloudfront.net

# ─── Monitoring ───────────────────────────────────────────────────────────────

# Sentry DSN for error tracking on the NestJS API
# Get yours at: https://sentry.io (create a Node.js project)
SENTRY_DSN=https://xxxx@o000000.ingest.sentry.io/0000000

# Betterstack Logtail source token for structured log aggregation
# Get yours at: https://betterstack.com/logs
LOGTAIL_SOURCE_TOKEN=xxxxxxxxxxxxxxxxxxxx
