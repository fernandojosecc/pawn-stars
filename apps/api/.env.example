# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (standard or Prisma Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pawnstars?sslmode=disable"

# ─── Application ─────────────────────────────────────────────────────────────
PORT=3001

# URL of the Next.js frontend (used for CORS allow-origin)
FRONTEND_URL="http://localhost:3000"

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
# Secret used to verify Auth.js JWT tokens signed by the frontend
JWT_SECRET="change-me-in-production"

# ─── External APIs ───────────────────────────────────────────────────────────
# Lichess public API base URL (no trailing slash)
LICHESS_API_URL="https://lichess.org/api"

# ─── Cache / Redis ────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Search / Meilisearch ─────────────────────────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# ─── Email / Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@pawnstars.com"

# ─── AI / Anthropic ───────────────────────────────────────────────────────────
# Used by ArticleGenerationService to generate post-tournament articles via Claude.
# Leave blank to use the built-in mock fallback (returns a realistic hardcoded article).
ANTHROPIC_API_KEY=""
